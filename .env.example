# Gemini (LLM)
GEMINI_API_KEY=...

# Pinecone (Vector DB)
PINECONE_API_KEY=pcsk-...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ecommerce-search

# HuggingFace (Embeddings)
HF_TOKEN=hf_...

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/ecommerce

# Redis
REDIS_URL=redis://localhost:6379

# LangSmith (optional tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ecommerce-search

# App
APP_ENV=development
LOG_LEVEL=INFO
